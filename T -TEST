#Студенты сдали тест до и после обучения. Оценки до: [68, 70, 72, 65, 74, 69, 71, 66, 73, 70], после: [70, 72, 75, 67, 77, 71, 73, 69, 76, 72]. Проверить, есть ли статистически значимое улучшение на уровне 0.05.

import numpy as np
from scipy import stats
# H - мю2 = мю1
# парный т тест
before = [68, 70, 72, 65, 74, 69, 71, 66, 73, 70]
after = [70, 72, 75, 67, 77, 71, 73, 69, 76, 72]
n = len(after)
sr = [after[i] - before[i] for i in range(n)]
mean = sum(sr)/n
l = 0
for i in sr:
l += (mean-i)**2
 
s = np.sqrt(l/(n-1))
t = mean*np.sqrt(n)/s
alpha = 0.05
df = n - 1
t_crit = stats.t.ppf(1 - alpha, df)
if t_crit < t:
print('результаты лучше')
else:
print('нет оснований полагать что результаты стали лучше')
